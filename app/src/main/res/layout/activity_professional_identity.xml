<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/design_default_color_background"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:padding="9dp"
            android:background="@drawable/ic_user_background"
            android:scaleType="centerCrop"
            android:src="@drawable/img"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/uploadproftext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Profile Photo"
            android:textSize="14sp"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/profileImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Upload Clearance -->
        <TextView
            android:id="@+id/uploadClearancetext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Clearance"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/uploadproftext"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/uploadClearanceExtaxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(Ex. NBI, Police, \nBarangay Clearance)"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/uploadClearancetext"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadClearancebtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Upload"
            android:textStyle="bold"
            app:icon="@drawable/baseline_arrow_upward_24"
            app:backgroundTint="#0D47A1"
            app:layout_constraintTop_toTopOf="@id/uploadClearancetext"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Upload ID -->
        <TextView
            android:id="@+id/uploadvalidIDtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Valid ID"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/uploadClearanceExtaxt"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadIDbtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Upload"
            android:textStyle="bold"
            app:icon="@drawable/baseline_arrow_upward_24"
            app:backgroundTint="#0D47A1"
            app:layout_constraintTop_toTopOf="@id/uploadvalidIDtext"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Preferred Location -->
        <TextView
            android:id="@+id/pref_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferred Location"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/uploadIDbtn"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/pref_location_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Choose Location"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:layout_constraintTop_toBottomOf="@id/pref_location"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <AutoCompleteTextView
                android:id="@+id/locationDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- DOB -->
        <TextView
            android:id="@+id/DOBinput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/pref_location_input"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/text_input_DOB"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="MM / DD / YYYY"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:layout_constraintTop_toBottomOf="@id/DOBinput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dobEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Salary Type -->
        <TextView
            android:id="@+id/salaryTypeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Salary Type"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/text_input_DOB"
            app:layout_constraintStart_toStartOf="parent"/>

        <RadioGroup
            android:id="@+id/salaryTypeGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/salaryTypeText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/radioHour" android:text="Per Hour"/>
            <RadioButton android:id="@+id/radioDay" android:text="Per Day"/>
            <RadioButton android:id="@+id/radioWeek" android:text="Per Week"/>
            <RadioButton android:id="@+id/radioMonth" android:text="Per Month"/>
            <RadioButton android:id="@+id/radioProject" android:text="Per Project"/>

        </RadioGroup>

        <!-- Salary Range -->
        <TextView
            android:id="@+id/salaryRangeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Salary Range"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/salaryTypeGroup"
            app:layout_constraintStart_toStartOf="parent"/>

        <RadioGroup
            android:id="@+id/salaryRangeGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/salaryRangeTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/savebtn"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="20dp"
            app:backgroundTint="#0D47A1"
            app:layout_constraintTop_toBottomOf="@id/salaryRangeGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>