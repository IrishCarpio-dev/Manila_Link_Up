<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/design_default_color_background"
    android:fillViewport="true"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Toolbar -->

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/design_default_color_background" />

        <!-- Profile Image -->

        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_below="@id/toolbar"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:background="@drawable/ic_user_background"
            android:padding="9dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img" />

        <TextView
            android:id="@+id/uploadproftext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/profileImage"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="5dp"
            android:text="Upload Profile Photo"
            android:textSize="14sp" />

        <!-- Upload Clearance -->

        <TextView
            android:id="@+id/uploadClearancetext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadproftext"
            android:layout_marginTop="30dp"
            android:text="Upload Clearance"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/uploadClearanceExtaxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadClearancetext"
            android:text="(Ex. NBI, Police, \nBarangay Clearance)"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadClearancebtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/uploadClearancetext"
            android:text="Upload"
            android:textStyle="bold"
            app:backgroundTint="#0D47A1"
            app:icon="@drawable/baseline_arrow_upward_24" />

        <!-- Upload ID -->

        <TextView
            android:id="@+id/uploadvalidIDtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadClearanceExtaxt"
            android:layout_marginTop="30dp"
            android:text="Upload Valid ID"
            android:textSize="15sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadIDbtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/uploadvalidIDtext"
            android:text="Upload"
            android:textStyle="bold"
            app:backgroundTint="#0D47A1"
            app:icon="@drawable/baseline_arrow_upward_24" />

        <!-- Preferred Location -->

        <TextView
            android:id="@+id/pref_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadvalidIDtext"
            android:layout_marginTop="30dp"
            android:text="Preferred Location"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/pref_location_input"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/pref_location"
            android:hint="Choose Location">

            <AutoCompleteTextView
                android:id="@+id/locationDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- DOB -->

        <TextView
            android:id="@+id/DOBinput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/pref_location_input"
            android:layout_marginTop="20dp"
            android:text="Date of Birth"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/text_input_DOB"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/DOBinput"
            android:hint="MM / DD / YYYY">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dobEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Salary Type -->

        <TextView
            android:id="@+id/salaryTypeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_input_DOB"
            android:layout_marginTop="20dp"
            android:text="Salary Type"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/salaryTypeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/salaryTypeText"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioHour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Per Hour" />

            <RadioButton
                android:id="@+id/radioDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Per Day" />

            <RadioButton
                android:id="@+id/radioWeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Per Week" />

            <RadioButton
                android:id="@+id/radioMonth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Per Month" />

            <RadioButton
                android:id="@+id/radioProject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Per Project" />

        </RadioGroup>

        <!-- Salary Range -->

        <TextView
            android:id="@+id/salaryRangeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/salaryTypeGroup"
            android:layout_marginTop="15dp"
            android:text="Salary Range"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/salaryRangeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/salaryRangeTitle"
            android:orientation="vertical" />

        <!-- Save Button -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/savebtn"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/salaryRangeGroup"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:text="Save"
            app:backgroundTint="#0D47A1" />

    </RelativeLayout>

</ScrollView>