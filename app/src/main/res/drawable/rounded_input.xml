<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- background color -->
    <solid android:color="#F3F4F6"/>

    <!-- rounded corners -->
    <corners android:radius="14dp"/>

    <!-- border -->
    <stroke
        android:width="1dp"
        android:color="#D1D5DB"/>

    <!-- inner spacing -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="12dp"
        android:bottom="12dp"/>

</shape>